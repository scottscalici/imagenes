    "lectura-s4-intiraymi": {
      "titulo": "El Inti Raymi: El renacimiento de la Fiesta del Sol",
      "subtitulo": "Lectura 📕",
      "imagen": "https://raw.githubusercontent.com/scottscalici/imagenes/main/curiosidad/inti-raymi-tickets-05-143.jpg?raw=true",
      "url": "https://sites.google.com/view/srscalici/lecturas/lectura-s4-intiraymi",
      "tag": "Perú",
      "courses": ["s4"],
      "dias": [13],
      "contenido": {
        "texto": [
          "El Inti Raymi, conocido como la “Fiesta del Sol”, es una de las celebraciones más espectaculares y significativas del mundo andino...",
          "Históricamente, el Inti Raymi era la ceremonia más importante del Imperio del Sol...",
          "La celebración moderna se desarrolla en tres escenarios históricos principales...",
          "Hoy en día, el Inti Raymi no es solo un evento turístico; es un símbolo de identidad y orgullo..."
        ],
        "preguntas": [
          {
            "tipo": "mc",
            "pregunta": "El Inti Raymi se celebra principalmente para conmemorar…",
            "opciones": ["A. La llegada de los españoles a Perú.", "B. El solsticio de invierno y al dios Sol.", "C. La fundación moderna de la ciudad de Cusco."],
            "correcta": 2
          },
          {
            "tipo": "vf",
            "pregunta": "La festividad del Inti Raymi ha tenido una historia ininterrumpida desde la época de los incas.",
            "correcta": false,
            "justificacion": "fue prohibida durante la época colonial"
          }
        ]
      }
    },
